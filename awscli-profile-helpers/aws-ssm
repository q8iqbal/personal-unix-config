#!/usr/bin/env bash
# aws-ssm — Start an SSM session (shell) to an EC2 instance
# Usage:
#   aws-ssm <name-tag>               (default: by Name tag)
#   aws-ssm --id <instance-id>

set -euo pipefail

usage() {
  cat <<EOF
Usage:
  aws-ssm <name-tag>
  aws-ssm --id <instance-id>

Options:
  --id    Use instance ID directly instead of Name tag
EOF
  exit 1
}

# Parse arguments
if [[ "${1:-}" == "--id" ]]; then
  shift
  instance_id="${1:?Missing instance ID. $(usage)}"
else
  name_tag="${1:?Missing Name tag. $(usage)}"

  instance_id=$(aws ec2 describe-instances \
    --filters "Name=tag:Name,Values=${name_tag}" "Name=instance-state-name,Values=running" \
    --query "Reservations[].Instances[].InstanceId" \
    --output text)

  if [[ -z "$instance_id" ]]; then
    echo "Error: No running instance found with Name tag '${name_tag}'" >&2
    exit 1
  fi

  # If multiple instances match, warn and use the first
  instance_count=$(echo "$instance_id" | wc -w)
  if [[ "$instance_count" -gt 1 ]]; then
    echo "Warning: ${instance_count} instances match Name '${name_tag}', using first: $(echo "$instance_id" | awk '{print $1}')" >&2
    instance_id=$(echo "$instance_id" | awk '{print $1}')
  fi
fi

echo "Starting SSM session to ${instance_id}..."

aws ssm start-session --target "$instance_id"
